---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Best of 2026 · SimRaceHub" description="Die besten Sim-Racing-Produkte des Jahres.">
  <section style="padding:60px 40px;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="mono" style="color:var(--accent);margin-bottom:12px;font-size:11px;letter-spacing:0.2em;">BEST OF 2026</div>
      <h1 class="headline" style="font-size:56px;margin:0 0 48px;">Die Gewinner des Jahres</h1>
      <p style="font-size:16px;color:var(--text-2);margin-bottom:60px;max-width:700px;">Handverlesene Top-Empfehlungen pro Kategorie — nach Tests, Community-Feedback und Preis-Leistung.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(500px,1fr));gap:24px;">
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:32px;">
          <div class="mono" style="color:var(--accent);margin-bottom:8px;font-size:9px;letter-spacing:0.16em;">BESTE WHEELBASE</div>
          <h2 class="headline" style="font-size:28px;margin-bottom:12px;">MOZA R9 V3</h2>
          <p style="color:var(--text-2);font-size:14px;line-height:1.6;margin-bottom:16px;">9 Nm, linear und leise. Der Sweet-Spot zwischen Realismus und Schreibtisch-Tauglichkeit.</p>
          <div style="display:flex;align-items:baseline;gap:12px;">
            <span class="headline" style="font-size:28px;color:var(--accent);">569 €</span>
            <span class="mono" style="color:var(--text-3);font-size:11px;">ab · 4 Shops</span>
          </div>
        </div>
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:32px;">
          <div class="mono" style="color:var(--accent);margin-bottom:8px;font-size:9px;letter-spacing:0.16em;">BESTE PEDALE</div>
          <h2 class="headline" style="font-size:28px;margin-bottom:12px;">Heusinkveld Sprint</h2>
          <p style="color:var(--text-2);font-size:14px;line-height:1.6;margin-bottom:16px;">Referenz-Loadcell. 100 kg, 3 Pedale, Stahl. Die Pedale der E-Sport-Elite.</p>
          <div style="display:flex;align-items:baseline;gap:12px;">
            <span class="headline" style="font-size:28px;color:var(--accent);">689 €</span>
            <span class="mono" style="color:var(--text-3);font-size:11px;">ab · 2 Shops</span>
          </div>
        </div>
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:32px;">
          <div class="mono" style="color:var(--accent);margin-bottom:8px;font-size:9px;letter-spacing:0.16em;">BESTES LENKRAD</div>
          <h2 class="headline" style="font-size:28px;margin-bottom:12px;">MOZA CS V2P</h2>
          <p style="color:var(--text-2);font-size:14px;line-height:1.6;margin-bottom:16px;">GT3-Style, Alcantara, 12 Tasten + 4 Encoder. Für Fans von Langstrecken-Rennen.</p>
          <div style="display:flex;align-items:baseline;gap:12px;">
            <span class="headline" style="font-size:28px;color:var(--accent);">379 €</span>
            <span class="mono" style="color:var(--text-3);font-size:11px;">ab · 3 Shops</span>
          </div>
        </div>
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:32px;">
          <div class="mono" style="color:var(--accent);margin-bottom:8px;font-size:9px;letter-spacing:0.16em;">BESTES COCKPIT</div>
          <h2 class="headline" style="font-size:28px;margin-bottom:12px;">Trak Racer TR8 PRO</h2>
          <p style="color:var(--text-2);font-size:14px;line-height:1.6;margin-bottom:16px;">80×40 Alu-Profil, 20 Nm max Drehmoment. Modular erweiterbar.</p>
          <div style="display:flex;align-items:baseline;gap:12px;">
            <span class="headline" style="font-size:28px;color:var(--accent);">599 €</span>
            <span class="mono" style="color:var(--text-3);font-size:11px;">ab · 2 Shops</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>