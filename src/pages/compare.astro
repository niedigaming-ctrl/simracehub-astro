---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Vergleich · SimRaceHub" description="Vergleiche bis zu 4 Sim-Racing-Produkte nebeneinander.">
  <section style="padding:60px 40px;min-height:60vh;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="mono" style="color:var(--accent);margin-bottom:12px;">VERGLEICHEN</div>
      <h1 class="headline" style="font-size:52px;margin:0 0 20px;">Side-by-Side Vergleich</h1>
      <p style="font-size:16px;color:var(--text-2);margin-bottom:40px;">Gehe zurück zur Startseite und klicke auf die ⚖ Buttons auf den Produktkarten, um bis zu 4 Produkte für den Vergleich auszuwählen.</p>
      <a href="/simracehub-astro/" class="btn btn-primary" style="height:48px;padding:0 32px;font-size:14px;">
        <svg width="10" height="10" viewBox="0 0 10 10"><path d="M7 1 L3 5 L7 9" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        Zurück zur Produktübersicht
      </a>
    </div>
  </section>
</BaseLayout>