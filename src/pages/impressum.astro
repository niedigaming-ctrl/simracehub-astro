---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum · SimRaceHub" description="Impressum — Angaben gemäß § 5 TMG">
  <section style="padding:60px 40px;min-height:60vh;">
    <div style="max-width:700px;margin:0 auto;">
      <h1 class="headline" style="font-size:42px;margin:0 0 32px;">Impressum</h1>
      <p style="color:var(--text-2);font-size:15px;line-height:1.8;">Angaben gemäß § 5 TMG</p>
      <p style="font-size:15px;line-height:1.8;margin-bottom:24px;">
        Martin Niederl<br/>
        Am Schützenplatz 9<br/>
        83435 Bad Reichenhall<br/>
        Deutschland
      </p>
      <p style="color:var(--text-2);font-size:15px;line-height:1.8;margin-bottom:8px;">Kontakt:</p>
      <p style="font-size:15px;line-height:1.8;margin-bottom:24px;">
        E-Mail: nied.martin@gmail.com
      </p>
      <p style="color:var(--text-2);font-size:15px;line-height:1.8;margin-bottom:8px;">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV:</p>
      <p style="font-size:15px;line-height:1.8;margin-bottom:32px;">Martin Niederl</p>
      <div style="border-top:1px solid var(--line);padding-top:24px;">
        <p style="font-size:13px;color:var(--text-3);">Haftungsausschluss: Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt. Eine Haftung für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte kann jedoch nicht übernommen werden.</p>
      </div>
    </div>
  </section>
</BaseLayout>