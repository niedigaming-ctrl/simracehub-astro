            <button class="fav-btn" data-id={p.id} title="Favorit" style="width:28px;height:28px;border:1px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.6);color:var(--text-2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;border-radius:3px;backdrop-filter:blur(4px);">♡</button>
          </div>
          <a href={`/simracehub-astro/produkte/${slug}/`} style="text-decoration:none;color:var(--text);display:block;">
          <div class="card-img" style={p.image ? `background-image:url('${p.image}');background-size:cover;background-position:center;` : ''}>
            {!p.image && <svg class="cat-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              {p.category==="wheelbase" && <><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/><path d="M12 6v-3M12 21v-3M6 12H3M21 12h-3"/></>}
              {p.category==="wheel" && <><circle cx="12" cy="12" r="8"/><path d="M4 12h16M12 4v3M12 17v3M7 7l2 2M17 17l-2-2"/></>}
              {p.category==="pedals" && <><rect x="4" y="6" width="4" height="12" rx="1"/><rect x="10" y="4" width="4" height="14" rx="1"/><rect x="16" y="6" width="4" height="12" rx="1"/></>}
              {p.category==="shifter" && <><circle cx="12" cy="6" r="2"/><path d="M12 8v10M8 18h8"/></>}
              {p.category==="cockpit" && <><path d="M4 18l4-12h8l4 12M7 14h10M9 18v3M15 18v3"/></>}
              {p.category==="monitor" && <><rect x="3" y="6" width="6" height="10" rx="0.5"/><rect x="9" y="4" width="6" height="14" rx="0.5"/><rect x="15" y="6" width="6" height="10" rx="0.5"/></>}
              {p.category==="seat" && <><path d="M7 4h6a3 3 0 0 1 3 3v9H7zM7 16v4M16 16v4"/></>}
              {p.category==="bundle" && <><rect x="3" y="8" width="18" height="12" rx="1"/><path d="M3 12h18M9 8v-3h6v3"/></>}
            </svg>}
            <div class="cat-label">{p.categoryLabel}</div>
            <div class="live-badge">// LIVE #{String(i+2).padStart(2,'0')}</div>
          </div>
          <div style="padding:16px;flex:1;display:flex;flex-direction:column;">
            <div class="mono" style="font-size:9px;color:var(--text-2);margin-bottom:4px;">{p.brand}</div>
            <h3 style="font-size:15px;font-weight:600;margin:0 0 6px;">{p.name}</h3>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
              <span class="stars">
                {[1,2,3,4,5].map(s => (
                  <svg key={s} width="12" height="12" viewBox="0 0 24 24" style="display:block;">
                    <path d="M12 2l3 6.5 7 1-5 4.8 1.2 7L12 18l-6.2 3.3L7 14.3 2 9.5l7-1z" fill={s <= Math.round(p.rating) ? "var(--accent)" : "rgba(255,255,255,0.15)"}/>
                  </svg>
                ))}
              </span>
              <span class="mono" style="font-size:9px;color:var(--text-2);">{p.rating.toFixed(1)} ({p.reviews})</span>
            </div>
            <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">Best für {p.bestFor}</div>
            <div class="platforms" style="margin-bottom:12px;">
              {p.platforms.map(pl => <span class="platform-chip">{pl}</span>)}
            </div>
            <div style="margin-top:auto;">
              <div style="display:flex;align-items:baseline;gap:8px;">
                <span class="headline" style="font-size:16px;color:var(--accent);">{fmtPrice(pmin)}</span>
                {p.shops.length > 1 && <span class="mono" style="font-size:9px;color:var(--text-3);">ab · {p.shops.filter(s=>s.inStock).length} Shops</span>}
              </div>
            </div>
          </div>
          </a>
          <div style="padding:0 16px 14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--line);padding-top:10px;">
              <span class="shop-count-btn btn" style="height:30px;padding:0 10px;font-size:10px;cursor:pointer;" data-slug={slug}>Preise ({p.shops.length})</span>
              <a href={`/simracehub-astro/produkte/${slug}/`} class="btn" style="height:30px;padding:0 10px;font-size:10px;">→</a>
            </div>
          </div>
        </div>
      );
    })}
