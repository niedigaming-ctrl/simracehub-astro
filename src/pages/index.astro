    {products.sort((a,b)=>b.rating - a.rating).map((p,i) => {
      const best = bestShop(p);
      const pmin = minPrice(p.shops);
      const pmax = maxPrice(p.shops);
      const slug = p.slug;
      return (
        <div class="card" data-cat={p.category} data-price={pmin} data-platform={p.platforms.join(',')} data-name={p.name.toLowerCase()} data-slug={slug}>
          {p.tag && <div class="card-ribbon">{p.tag}</div>}
