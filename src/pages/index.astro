---
// index.astro — SimRaceHub Startseite (Content only, Layout comes from BaseLayout)
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/products.json';

function bestShop(p) {
  if (!p || !p.shops || !p.shops.length) return null;
  const sorted = [...p.shops].sort((a,b) => (a.price || 0) - (b.price || 0));
  return sorted.find(s => s.inStock) || sorted[0];
}
function fmtPrice(p) { return (p || 0).toLocaleString("de-DE") + " €"; }
function minPrice(shops) { 
  const prices = (shops || []).filter(s=>s.inStock).map(s=>s.price || 0);
  return prices.length ? Math.min(...prices) : 0; 
}
function maxPrice(shops) { 
  const prices = (shops || []).filter(s=>s.inStock).map(s=>s.price || 0);
  return prices.length ? Math.max(...prices) : 0; 
}

const { hero, products, categories } = data;
const heroBest = bestShop(hero);
const heroMin = minPrice(hero.shops);
const heroMax = maxPrice(hero.shops);
const productsJson = JSON.stringify(products || []);
---

<BaseLayout
  title="SimRaceHub · Sim Racing Kaufberatung & Preisvergleich"
  description="Unabhängige Kaufberatung für Sim Racing. Live-Preise von Amazon, Caseking, Alternate & mehr. Vergleiche 13+ Produkte für Wheelbase, Lenkrad, Pedale & Cockpit."
  noindex={false}
>
  <!-- Products data for JS -->
  <script type="application/json" id="srh-products-data">{productsJson}</script>

  <!-- HERO -->
  <section style="padding:40px 40px 30px;display:grid;grid-template-columns:1.05fr 1fr;gap:48px;align-items:center;border-bottom:1px solid var(--line);" class="hero-grid">
    <div>
      <div class="mono" style="font-size:11px;letter-spacing:0.22em;color:var(--accent);text-transform:uppercase;margin-bottom:18px;display:flex;align-items:center;gap:10px;">
        <span style="width:24px;height:1px;background:var(--accent);"></span>
        EDITOR'S PICK · {hero.badge || 'TOP'}
      </div>
      <h1 class="headline headline-84" style="font-size:84px;margin:0 0 18px;line-height:0.95;">
        {hero.name ? hero.name.split(" ")[0] : ''} {hero.name ? hero.name.split(" ")[1] : ''}<br/>
        <span style="color:var(--accent);">{hero.name ? hero.name.split(" ").slice(2).join(" ") : ''}</span>
      </h1>
      <p style="margin:0 0 24px;font-size:15px;color:var(--text-2);max-width:480px;line-height:1.6;">{hero.blurb}</p>
      
      <div style="display:grid;grid-template-columns:repeat(3,auto);gap:32px;margin-bottom:32px;">
        {(hero.specs || []).map(([k,v]) => (
          <div>
            <div class="mono" style="font-size:10px;color:var(--text-3);letter-spacing:0.16em;text-transform:uppercase;margin-bottom:6px;">{k}</div>
            <div class="headline" style="font-size:24px;">{v}</div>
          </div>
        ))}
      </div>

      <div style="display:flex;align-items:center;gap:18px;margin-bottom:24px;">
        <div>
          <div class="mono" style="font-size:10px;color:var(--text-3);letter-spacing:0.14em;text-transform:uppercase;">
            Bestpreis · {(hero.shops || []).length} Shops
          </div>
          <div style="display:flex;align-items:baseline;gap:14px;">
            <span class="headline" style="font-size:42px;color:var(--accent);">{fmtPrice(heroBest?.price || 0)}</span>
          </div>
        </div>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="#produkte" class="btn btn-primary" style="font-size:15px;">Alle Produkte ansehen</a>
        <a href="/simracehub-astro/quiz/" class="btn" style="font-size:15px;">Kaufberater starten →</a>
      </div>
    </div>
    
    <div style="position:relative;">
      <div class="card" style="padding:0;overflow:hidden;border-radius:12px;">
        <img src={hero.image || products[0]?.image} alt={hero.name} style="width:100%;display:block;" />
      </div>
    </div>
  </section>

  <!-- PRODUKTE -->
  <section id="produkte" style="padding:60px 40px;">
    <div style="max-width:1400px;margin:0 auto;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:32px;">
        <div>
          <div class="mono" style="color:var(--accent);font-size:11px;letter-spacing:0.2em;margin-bottom:8px;">LIVE PREISE 2026</div>
          <h2 class="headline" style="font-size:42px;margin:0;">Aktuelle Top-Produkte</h2>
        </div>
        <a href="/simracehub-astro/compare/" style="color:var(--accent);font-size:14px;">Vollständigen Vergleich →</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;">
        {(products || []).sort((a,b) => (b.rating || 0) - (a.rating || 0)).slice(0,12).map((p,i) => {
          const bp = bestShop(p);
          return (
            <a href={`/simracehub-astro/produkte/${p.slug}/`} style="text-decoration:none;color:inherit;">
              <div class="card" style="padding:0;height:100%;transition:transform .2s;">
                <div style="height:220px;background:#111;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                  <img src={p.image} alt={p.name} style="max-height:200px;max-width:90%;object-fit:contain;" />
                </div>
                <div style="padding:24px;">
                  <div style="font-size:12px;color:var(--text-3);margin-bottom:4px;">{p.categoryLabel || p.category}</div>
                  <h3 style="font-size:20px;line-height:1.2;margin:0 0 16px;">{p.name}</h3>
                  
                  <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:16px;">
                    <div>
                      <div style="font-size:11px;color:var(--text-3);">ab</div>
                      <div style="font-size:26px;font-weight:700;color:var(--accent);">{fmtPrice(bp?.price || 0)}</div>
                    </div>
                    <div style="text-align:right;">
                      <div style="font-size:12px;color:var(--text-3);">{(p.shops || []).length} Shops</div>
                    </div>
                  </div>

                  <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    {(p.platforms || []).map(pl => <span class="platform-chip">{pl}</span>)}
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>