---
import data from '../data/products.json';

// helpers
function bestShop(p) {
  if (!p || !p.shops || !p.shops.length) return null;
  const sorted = [...p.shops].sort((a,b) => a.price - b.price);
  return sorted.find(s => s.inStock) || sorted[0];
}
function fmtPrice(p) { return p.toLocaleString("de-DE") + " €"; }
function minPrice(shops) { return Math.min(...shops.filter(s=>s.inStock).map(s=>s.price)); }
function maxPrice(shops) { return Math.max(...shops.filter(s=>s.inStock).map(s=>s.price)); }

const {hero, products, categories} = data;
const heroBest = bestShop(hero);
const heroMin = minPrice(hero.shops);
const heroMax = maxPrice(hero.shops);

const productsJson = JSON.stringify(products);
---
<html lang="de">
