<style>
:root {
  --bg: #0a0a0a;
  --panel: #111111;
  --panel-2: #181818;
  --line: rgba(255,255,255,0.07);
  --line-2: rgba(255,255,255,0.16);
  --text: #fafafa;
  --text-2: #a0a0a0;
  --text-3: #5e5e5e;
  --accent: #ff2d2d;
  --sans: 'Inter', system-ui, sans-serif;
  --mono: 'JetBrains Mono', ui-monospace, monospace;
  --display: 'Barlow Condensed', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; }
html, body { margin:0; padding:0; background:var(--bg); color:var(--text); font-family:var(--sans); font-size:15px; line-height:1.5; }
::selection { background:var(--accent); color:#0a0a0a; }
a { color:inherit; text-decoration:none; }
img { max-width:100%; display:block; }

.headline { font-family:var(--display); font-weight:700; line-height:0.95; text-transform:uppercase; letter-spacing:-0.005em; }
.mono { font-family:var(--mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; }

.btn { display:inline-flex; align-items:center; gap:8px; height:38px; padding:0 16px; border:1px solid var(--line-2); background:transparent; color:var(--text); font-family:var(--mono); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:all .15s; text-decoration:none; }
.btn:hover { background:var(--panel-2); border-color:var(--accent); }
.btn-primary { background:var(--accent); color:#0a0a0a; border-color:var(--accent); font-weight:600; }
.btn-primary:hover { filter:brightness(1.1); }

.pill { display:inline-flex; align-items:center; gap:6px; padding:8px 14px; background:transparent; border:1px solid var(--line); color:var(--text-2); font-family:var(--mono); font-size:10px; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:all .12s; white-space:nowrap; }
.pill:hover { color:var(--text); border-color:var(--line-2); }
.pill.active { background:var(--text); color:#0a0a0a; border-color:var(--text); font-weight:600; }

.card { background:var(--panel); border:1px solid var(--line); position:relative; transition:all .2s; display:flex; flex-direction:column; overflow:visible; }
.card:hover { border-color:var(--accent); transform:translateY(-3px); }
.card-ribbon { position:absolute; top:14px; left:0; background:var(--accent); color:#0a0a0a; padding:5px 12px; font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; z-index:2; }

.spec-row { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid var(--line); font-size:12px; }
.spec-row:last-child { border-bottom:none; }

.shop-list { background:#0a0a0a; border:1px solid var(--accent); z-index:50; padding:0; box-shadow:0 8px 24px rgba(0,0,0,.6); display:none; }
.shop-row { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-bottom:1px solid var(--line); text-decoration:none; color:var(--text); transition:background .12s; }
.shop-row:last-child { border-bottom:none; }
.shop-row:hover { background:rgba(255,255,255,.04); }

.platform-chip { font-family:var(--mono); font-size:9px; letter-spacing:0.08em; padding:2px 6px; border:1px solid rgba(255,255,255,0.14); color:var(--text-2); text-transform:uppercase; }

.card-img { width:100%; height:180px; background:linear-gradient(180deg,#161616,#0d0d0d); border-bottom:1px solid var(--line); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:8px; position:relative; }
.card-img .cat-icon { opacity:0.32; }
.card-img .cat-label { font-family:var(--mono); font-size:9px; letter-spacing:0.12em; color:rgba(255,255,255,0.3); text-transform:uppercase; }
.card-img .live-badge { position:absolute; left:12px; top:12px; font-family:var(--mono); font-size:8px; letter-spacing:0.16em; color:rgba(255,255,255,0.3); }

.stars { display:inline-flex; align-items:center; gap:2px; }
.star { color:rgba(255,255,255,0.15); }
.star.filled { color:var(--accent); }

.platforms { display:flex; gap:4px; }

@media (max-width:980px) {
  header, section, footer { padding-left:20px !important; padding-right:20px !important; }
  .hero-grid { grid-template-columns:1fr !important; }
  .prod-grid { grid-template-columns:repeat(2,1fr) !important; }
  .detail-grid { grid-template-columns:1fr !important; }
}
@media (max-width:620px) {
  .prod-grid { grid-template-columns:1fr !important; }
  .headline-84 { font-size:54px !important; }
}
</style>
</head>
<body>

<div style="background:#000;border-bottom:1px solid var(--line);padding:7px 40px;display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:0.16em;color:var(--text-3);text-transform:uppercase;gap:12;flex-wrap:wrap;">
