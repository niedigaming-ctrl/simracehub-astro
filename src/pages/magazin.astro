---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Magazin · SimRaceHub" description="Ratgeber, Vergleiche & Insights für Sim Racing.">
  <section style="padding:60px 40px;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="mono" style="color:var(--accent);margin-bottom:12px;font-size:11px;letter-spacing:0.2em;">MAGAZIN</div>
      <h1 class="headline" style="font-size:52px;margin:0 0 48px;">Ratgeber, Vergleiche & Insights</h1>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:24px;">
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">KAUFBERATUNG · 8 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">Direct Drive vs. Belt Drive</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">Was lohnt sich wirklich 2026? Der Unterschied zwischen einem 200 € Belt-Drive und einem 600 € Direct-Drive ist größer als du denkst.</p>
        </article>
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">EINSTEIGER-GUIDE · 6 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">Sim Racing unter 500 €</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">Das beste Budget-Setup: optimale Kombinationen aus Wheelbase, Lenkrad und Pedalen.</p>
        </article>
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">VERGLEICH · 10 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">MOZA R9 vs. Fanatec CSL DD</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">9 Nm gegen 8 Nm — klingt nach Haarspalterei, ist es aber nicht. 100 Stunden getestet.</p>
        </article>
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">HARDWARE · 5 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">Monitor oder VR?</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">Triple-Screen, UltraWide oder VR? Die richtige Wahl für dein Setup.</p>
        </article>
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">ERGONOMIE · 7 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">Cockpit-Kaufberatung</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">Vom Faltstuhl bis zum Alu-Profil-Rig — was du wirklich brauchst.</p>
        </article>
        <article style="background:var(--panel);border:1px solid var(--line);padding:32px;transition:all .2s;">
          <div class="mono" style="font-size:9px;color:var(--text-3);margin-bottom:8px;">LONGREAD · 12 MIN</div>
          <h3 class="headline" style="font-size:22px;line-height:1.1;margin-bottom:12px;">Loadcell-Pedale erklärt</h3>
          <p style="font-size:14px;color:var(--text-2);line-height:1.6;">Warum 90 % der schnellen Fahrer sie nutzen — die Physik hinter der Bremse.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>