---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/products.json';

export function getStaticPaths() {
  return (data.products || []).map(p => ({
    params: { slug: p.slug || 'unknown' },
    props: { product: p }
  }));
}

const { product } = Astro.props;

function bestShop(p) {
  if (!p || !p.shops || !p.shops.length) return null;
  const sorted = [...p.shops].sort((a,b) => (a.price || 0) - (b.price || 0));
  return sorted.find(s => s.inStock) || sorted[0];
}

function fmtPrice(p) { return (p || 0).toLocaleString("de-DE") + " €"; }
function minPrice(shops) { 
  const prices = (shops || []).filter(s=>s.inStock).map(s=>s.price || 0);
  return prices.length ? Math.min(...prices) : 0; 
}

const best = bestShop(product);
const pmin = minPrice(product.shops);
---

<BaseLayout
  title={`${product.name} · SimRaceHub`}
  description={product.blurb || product.categoryLabel}
  ogImage={product.image}
>
  <section style="padding:40px;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;" class="detail-grid">
      <div>
        {product.tag && <div class="card-ribbon">{product.tag}</div>}
        <div class="card-img" style="height:400px;margin-bottom:24px;">
          <img src={product.image} alt={product.name} style="width:100%;height:100%;object-fit:contain;border-radius:8px;" />
        </div>
      </div>
      <div>
        <div style="margin-bottom:8px;color:var(--accent);font-size:13px;">{product.categoryLabel}</div>
        <h1 style="font-size:42px;line-height:1.1;margin:0 0 24px;">{product.name}</h1>
        
        <div style="font-size:32px;font-weight:700;margin-bottom:32px;">
          {fmtPrice(pmin)}
        </div>

        <div style="margin-bottom:32px;">
          <a href={best?.url || '#'} target="_blank" class="btn btn-primary" style="font-size:15px;padding:14px 32px;">
            Jetzt kaufen →
          </a>
        </div>

        <div style="color:var(--text-2);line-height:1.7;">
          {product.blurb}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>