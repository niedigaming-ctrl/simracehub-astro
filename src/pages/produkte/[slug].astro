---
// [slug].astro — Produkt-Detailseite (Content only, Layout comes from BaseLayout)
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/products.json';

export function getStaticPaths() {
  return data.products.map(p => ({
    params: { slug: p.slug },
    props: { product: p }
  }));
}

const { product } = Astro.props;

function bestShop(p) {
  if (!p || !p.shops || !p.shops.length) return null;
  const sorted = [...p.shops].sort((a,b) => a.price - b.price);
  return sorted.find(s => s.inStock) || sorted[0];
}
function fmtPrice(p) { return p.toLocaleString("de-DE") + " €"; }
function minPrice(shops) { return Math.min(...shops.filter(s=>s.inStock).map(s=>s.price)); }

const best = bestShop(product);
const pmin = minPrice(product.shops);
---

<BaseLayout
  title={`${product.name} · SimRaceHub`}
  description={product.blurb || product.categoryLabel}
  ogImage={product.image}
>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "{product.name}",
    "brand": { "@type": "Brand", "name": "{product.brand}" },
    "description": "{product.categoryLabel}",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "{product.rating}", "reviewCount": "{product.reviews}" },
    "offers": { "@type": "Offer", "price": "{pmin}", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" }
  }
  </script>

  <section style="padding:40px;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;" class="detail-grid">
      <div>
        {product.tag && <div class="card-ribbon">{product.tag}</div>}
        <div class="card-img" style="height:400px;margin-bottom:24px;">
          <svg class="cat-icon" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.6">
            {product.category==="wheelbase" && <><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/><path d="M12 6v-3M12 21v-3M6 12H3M21 12h-3"/></>}
            {product.category==="wheel" && <><circle cx="12" cy="12" r="8"/><path d="M4 12h16M12 4v3M12 17v3"/></>}
            {product.category==="pedals" && <><rect x="4" y="6" width="4" height="12" rx="1"/><rect x="10" y="4" width="4" height="14" rx="1"/><rect x="16" y="6" width="4" height="12" rx="1"/></>}
            {product.category==="cockpit" && <><path d="M4 18l4-12h8l4 12"/></>}
            {product.category==="bundle" && <><rect x="3" y="8" width="18" height="12" rx="1"/><path d="M3 12h18"/></>}
          </svg>
          <div class="cat-label">{product.categoryLabel}</div>
        </div>
        <div class="mono" style="font-size:9px;color:var(--text-2);margin-bottom:4px;">{product.brand}</div>
        <h1 class="headline" style="font-size:42px;margin:0 0 12px;">{product.name}</h1>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
          <span class="stars">
            {[1,2,3,4,5].map(s => (
              <svg width="16" height="16" viewBox="0 0 24 24">
                <path d="M12 2l3 6.5 7 1-5 4.8 1.2 7L12 18l-6.2 3.3L7 14.3 2 9.5l7-1z" fill={s <= Math.round(product.rating) ? "var(--accent)" : "rgba(255,255,255,0.15)"}/>
              </svg>
            ))}
          </span>
          <span class="mono" style="color:var(--text-2);">{product.rating.toFixed(1)} ({product.reviews} Reviews)</span>
        </div>
        <div class="platforms" style="display:flex;gap:6px;margin-bottom:24px;">
          {product.platforms.map(pl => <span class="platform-chip">{pl}</span>)}
        </div>
        <p style="font-size:15px;color:var(--text-2);line-height:1.7;margin-bottom:32px;">{product.blurb || product.categoryLabel}</p>

        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:32px;">
          <a href={best?.url || "#"} class="btn btn-primary btn-lg" target="_blank" rel="nofollow">Zum Bestpreis</a>
          <div class="btn btn-lg" style="cursor:default;">
            <span class="headline" style="font-size:20px;color:var(--accent);">{fmtPrice(pmin)}</span>
          </div>
        </div>
      </div>

      <div>
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:12px;overflow:hidden;margin-bottom:24px;">
          {product.image ? (
            <img src={product.image} alt={product.name} style="width:100%;height:340px;object-fit:cover;object-position:center;display:block;" />
          ) : (
            <div style="width:100%;height:340px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;background:linear-gradient(180deg,#161616,#0d0d0d);">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/></svg>
              <span style="font-family:var(--mono);font-size:9px;letter-spacing:0.12em;color:rgba(255,255,255,0.3);text-transform:uppercase;">PRODUKTBILD</span>
            </div>
          )}
        </div>

        <!-- Specifications -->
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:24px;margin-bottom:24px;">
          <h2 class="headline" style="font-size:20px;margin:0 0 16px;">Spezifikationen</h2>
          <table class="spec-table" style="width:100%;border-collapse:collapse;">
            {product.specs.map(([k,v]) => (
              <tr><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;color:var(--text-2);width:45%;">{k}</td><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;text-align:right;">{v}</td></tr>
            ))}
            <tr><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;color:var(--text-2);width:45%;">Marke</td><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;text-align:right;">{product.brand}</td></tr>
            <tr><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;color:var(--text-2);width:45%;">Kategorie</td><td style="padding:10px 0;border-bottom:1px solid var(--line);font-size:13px;text-align:right;">{product.categoryLabel}</td></tr>
            <tr><td style="padding:10px 0;font-size:13px;color:var(--text-2);width:45%;">Plattform</td><td style="padding:10px 0;font-size:13px;text-align:right;">{product.platforms.join(", ")}</td></tr>
          </table>
        </div>

        <!-- Live Prices -->
        <div style="background:var(--panel);border:1px solid var(--line);border-radius:12px;overflow:hidden;">
          <div style="padding:16px;border-bottom:1px solid var(--line);">
            <h2 class="headline" style="font-size:18px;margin:0;">Live-Preise</h2>
          </div>
          {product.shops.map(shop => {
            const isBest = shop.price === pmin && shop.inStock;
            return (
              <div style="display:flex;justify-content:space-between;align-items:center;padding:14px;border-bottom:1px solid var(--line);">
                <div>
                  <div style="font-weight:600;">{shop.name}</div>
                  {shop.badge && <div class="mono" style="font-size:8px;color:var(--text-3);margin-top:4px;">{shop.badge}</div>}
                </div>
                <div style="text-align:right;">
                  <div class={isBest ? "headline" : ""} style={`font-size:18px;${isBest ? 'color:var(--accent);font-weight:700;' : ''}`}>{fmtPrice(shop.price)}</div>
                  {isBest && <div class="mono" style="font-size:8px;color:var(--accent);">✓ Bestpreis</div>}
                  {!shop.inStock && <div class="mono" style="font-size:8px;color:var(--text-3);">Nicht lieferbar</div>}
                </div>
                <div>
                  {shop.inStock ? (
                    <a href={shop.url || "#"} class="btn btn-primary" target="_blank" rel="nofollow">Zum Shop →</a>
                  ) : (
                    <span class="btn" style="opacity:.4;cursor:not-allowed;">Ausverkauft</span>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
